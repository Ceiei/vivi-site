---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Tag from "./Tag.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, tags, pubDatetime, modDatetime } = data;
const updatedDate = modDatetime ?? pubDatetime;
const formattedUpdatedDate = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
}).format(updatedDate);
---

<li>
  <article
    class="rounded-3xl border border-border bg-muted/20 p-5 transition hover:border-accent/50 hover:bg-muted/30"
  >
    <div class="flex flex-wrap items-start justify-between gap-4">
      <a
        href={getPath(id, filePath)}
        class:list={[
          "text-xl font-semibold text-foreground transition hover:text-accent",
          "focus-visible:no-underline focus-visible:underline-offset-0",
        ]}
      >
        <Heading
          style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
        >
          {title}
        </Heading>
      </a>

      <p class="shrink-0 text-sm text-foreground/60">
        上次修改：<time datetime={updatedDate.toISOString()}
          >{formattedUpdatedDate}</time
        >
      </p>
    </div>

    <p class="mt-4 leading-7 text-foreground/80">{description}</p>

    <ul class="mt-4 flex flex-wrap gap-3">
      {tags.map(tag => <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />)}
    </ul>
  </article>
</li>
