---
type Props = {
  title: string;
  meta: string;
  timeframe: string;
  subtitle?: string;
  description?: string[];
};

const { title, meta, timeframe, subtitle, description = [] } = Astro.props;
---

<li class="relative pl-7">
  <span class="absolute left-0 top-5 h-full w-px bg-border/80"></span>
  <span class="absolute left-[-3px] top-5 size-2.5 rounded-full bg-accent ring-4 ring-accent/15"></span>

  <article class="rounded-2xl border border-border bg-muted/20 p-5 transition-colors hover:border-accent/40 hover:bg-muted/30">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <h3 class="text-lg font-semibold text-foreground">{title}</h3>
        <p class="mt-1 text-sm font-medium text-accent">{meta}</p>
      </div>
      <span class="text-sm text-muted-foreground">{timeframe}</span>
    </div>

    {subtitle && <p class="mt-3 text-sm font-medium text-foreground/90">{subtitle}</p>}

    {description.length > 0 && (
      <div class="mt-3 space-y-2 text-sm leading-7 text-foreground/80">
        {description.map(line => <p>{line}</p>)}
      </div>
    )}
  </article>
</li>
