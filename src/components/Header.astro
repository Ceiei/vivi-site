---
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import { SITE } from "@/config";
import { stripBase, withBase } from "@/utils/withBase";

const { pathname } = Astro.url;
const pathnameWithoutBase = stripBase(pathname);

const currentPath =
  pathnameWithoutBase.endsWith("/") && pathnameWithoutBase !== "/"
    ? pathnameWithoutBase.slice(0, -1)
    : pathnameWithoutBase;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<header
  class="app-layout flex flex-col items-center justify-between sm:flex-row"
>
  <div
    id="top-nav-wrap"
    class:list={[
      "py-4 sm:py-6",
      "border-b border-border",
      "w-full bg-background",
      "flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between",
    ]}
  >
    <a
      href={withBase("/")}
      class="py-1 text-xl leading-8 font-semibold whitespace-nowrap sm:my-auto sm:text-2xl sm:leading-none"
    >
      {SITE.title}
    </a>
    <nav
      class="flex w-full items-center justify-between gap-4 sm:ms-2 sm:w-auto sm:justify-end"
    >
      <ul
        class:list={[
          "flex flex-wrap items-center gap-x-4 gap-y-2",
          "[&>li>a]:block [&>li>a]:py-1 [&>li>a]:font-medium [&>li>a]:hover:text-accent",
        ]}
      >
        <li>
          <a href={withBase("/")} class:list={{ "active-nav": isActive("/") }}>
            关于我
          </a>
        </li>
        <li>
          <a
            href={withBase("/blog")}
            class:list={{ "active-nav": isActive("/blog") }}
          >
            AI学习笔记
          </a>
        </li>
        <li>
          <a
            href={withBase("/projects")}
            class:list={{ "active-nav": isActive("/projects") }}
          >
            项目展示
          </a>
        </li>
        <li>
          <a
            href={withBase("/notes")}
            class:list={{ "active-nav": isActive("/notes") }}
          >
            碎碎念
          </a>
        </li>
      </ul>
      {
        SITE.lightAndDarkMode && (
          <button
            id="theme-btn"
            class="focus-outline relative size-10 shrink-0 p-3 sm:size-8 sm:p-4 hover:[&>svg]:stroke-accent"
            title="Toggles light & dark"
            aria-label="auto"
            aria-live="polite"
          >
            <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
            <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
          </button>
        )
      }
    </nav>
  </div>
</header>
