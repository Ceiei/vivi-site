---
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";
import { withBase } from "@/utils/withBase";

type Props = {
  href?: string;
  label?: string;
};

const { href, label = "返回上一级" } = Astro.props;
const resolvedHref = href ? withBase(href) : withBase("/");
---

{
  SITE.showBackButton && (
    <div class="app-layout flex items-center justify-start">
      <LinkButton
        id="back-button"
        href={resolvedHref}
        data-static-back-url={href ? "true" : undefined}
        class="focus-outline -ms-2 mt-8 mb-2 hover:text-foreground/75"
      >
        <IconChevronLeft class="inline-block size-6 rtl:rotate-180" />
        <span>{label}</span>
      </LinkButton>
    </div>
  )
}

<script>
  /* Update Search Praam */
  function updateGoBackUrl() {
    const backButton: HTMLAnchorElement | null =
      document.querySelector("#back-button");

    const backUrl = sessionStorage.getItem("backUrl");
    const hasStaticBackUrl = backButton?.dataset.staticBackUrl === "true";

    if (backUrl && backButton && !hasStaticBackUrl) {
      backButton.href = backUrl;
    }
  }

  document.addEventListener("astro:page-load", updateGoBackUrl);
  updateGoBackUrl();
</script>
