---
type NavItem = {
  href: string;
  label: string;
};

type Props = {
  title?: string;
  items: NavItem[];
};

const { title = "页面导航", items } = Astro.props;
---

<aside
  class="pointer-events-none fixed top-1/2 z-30 hidden -translate-y-1/2 [@media(min-width:1420px)]:block"
  style="right: max(1.25rem, calc((100vw - 72rem) / 2 - 9rem));"
>
  <nav
    class="pointer-events-auto relative pl-8"
    aria-label={title}
    data-side-nav
  >
    <span
      class="absolute top-4 bottom-4 left-3 border-l border-dashed border-accent/45"
      aria-hidden="true"></span>
    <span
      class="absolute left-0 text-accent transition-transform duration-300 ease-out"
      style="transform: translateY(var(--plane-y, 0px));"
      data-side-nav-plane
      aria-hidden="true"
    >
      <svg
        viewBox="0 0 24 24"
        class="size-6 -rotate-12 drop-shadow-sm"
        fill="none"
      >
        <path
          d="M3.5 11.5 20 4l-6.2 16-3-6.7-7.3-1.8Z"
          class="fill-background stroke-accent"
          stroke-width="1.7"
          stroke-linejoin="round"></path>
        <path
          d="m10.8 13.3 3.4-3.4"
          class="stroke-accent"
          stroke-width="1.7"
          stroke-linecap="round"></path>
      </svg>
    </span>

    <ol class="space-y-3">
      {
        items.map(item => (
          <li>
            <a
              href={item.href}
              class="block py-1 text-sm font-medium text-foreground/55 transition hover:translate-x-1 hover:text-accent aria-current:text-accent"
              data-side-nav-link
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ol>
  </nav>
</aside>

<script is:inline>
  function initSideNav() {
    document.querySelectorAll("[data-side-nav]").forEach(nav => {
      if (nav.dataset.sideNavReady === "true") return;
      nav.dataset.sideNavReady = "true";

      const plane = nav.querySelector("[data-side-nav-plane]");
      const links = Array.from(nav.querySelectorAll("[data-side-nav-link]"));
      const sections = links
        .map(link => {
          const target = document.querySelector(link.hash);
          return target ? { link, target } : null;
        })
        .filter(Boolean);

      let activeLink = links[0];
      let clickedLink = null;
      let clickTimer;

      const movePlane = link => {
        if (!plane || !link) return;
        const linkBox = link.getBoundingClientRect();
        const navBox = nav.getBoundingClientRect();
        const y = linkBox.top - navBox.top + linkBox.height / 2 - 12;
        nav.style.setProperty("--plane-y", `${y}px`);
      };

      const setActive = link => {
        activeLink?.removeAttribute("aria-current");
        activeLink = link;
        activeLink?.setAttribute("aria-current", "true");
        movePlane(activeLink);
      };

      links.forEach(link => {
        link.addEventListener("click", () => {
          clickedLink = link;
          setActive(link);
          window.clearTimeout(clickTimer);
          clickTimer = window.setTimeout(() => {
            clickedLink = null;
          }, 1200);
        });
        link.addEventListener("mouseenter", () => movePlane(link));
        link.addEventListener("focus", () => movePlane(link));
        link.addEventListener("mouseleave", () => movePlane(activeLink));
        link.addEventListener("blur", () => movePlane(activeLink));
      });

      const observer = new IntersectionObserver(
        entries => {
          const visibleEntry = entries
            .filter(entry => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

          if (!visibleEntry) return;
          const current = sections.find(
            section => section.target === visibleEntry.target
          );
          if (clickedLink && current?.link !== clickedLink) return;
          if (clickedLink && current?.link === clickedLink) {
            clickedLink = null;
            window.clearTimeout(clickTimer);
          }
          if (current) setActive(current.link);
        },
        {
          rootMargin: "-35% 0px -50% 0px",
          threshold: [0.1, 0.35, 0.6],
        }
      );

      sections.forEach(section => observer.observe(section.target));
      requestAnimationFrame(() => setActive(activeLink));
      window.addEventListener("resize", () => movePlane(activeLink));
    });
  }

  initSideNav();
  document.addEventListener("astro:page-load", initSideNav);
</script>
