---
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

const notes = await getCollection("notes");
const sortedNotes = notes.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const renderedNotes = await Promise.all(
  sortedNotes.map(async note => {
    const { Content } = await render(note);
    return { ...note, Content };
  })
);

const dateFormatter = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title={`碎碎念 | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout py-12 sm:py-16">
    <section>
      <p class="mb-3 text-sm font-medium text-accent">Notes</p>
      <h1 class="text-3xl font-bold sm:text-4xl">碎碎念</h1>
      <p class="mt-4 max-w-2xl leading-8">
        {/* // TODO: 替换为你的碎碎念页面介绍 */}
        这里放一些更短、更松散的记录，不一定成文，也不一定完整。
      </p>
    </section>

    <section class="mt-10 columns-1 gap-5 sm:columns-2">
      {
        renderedNotes.map(({ data, Content }) => (
          <article class="mb-5 break-inside-avoid rounded border border-border p-5">
            <div class="mb-4 flex items-center justify-between gap-4 text-sm text-foreground/70">
              <time datetime={data.date.toISOString()}>
                {dateFormatter.format(data.date)}
              </time>
              {data.mood && <span aria-label="mood">{data.mood}</span>}
            </div>
            <div class="app-prose text-sm leading-7">
              <Content />
            </div>
          </article>
        ))
      }
    </section>
  </main>
  <Footer />
</Layout>
