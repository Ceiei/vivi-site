---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import IconGitHub from "@/assets/icons/IconGitHub.svg";
import IconMail from "@/assets/icons/IconMail.svg";
import avatar from "@/assets/avatar.jpg";
import { SITE } from "@/config";

// TODO: 替换为你的技能列表
const skills = ["Machine Learning", "Deep Learning", "LLM"];
const email = "18662816018@163.com";
const avatarSrc = avatar.src ?? avatar;

// TODO: 替换为你的联系方式
const contacts = [
  {
    name: "GitHub",
    href: "https://github.com/Ceiei",
    icon: IconGitHub,
  },
  {
    name: "Email",
    href: `${email}`,
    icon: IconMail,
  },
];
---

<Layout title={`关于我 | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout py-12 sm:py-16">
    <section class="flex flex-col gap-8 sm:flex-row sm:items-center">
      <div
        class="size-36 shrink-0 overflow-hidden rounded-full border border-border bg-muted/30"
        aria-label="头像占位区"
      >
        <img
          src={avatarSrc}
          alt="头像"
          class="size-full object-cover"
          loading="eager"
        />
      </div>

      <div>
        <p class="mb-3 text-sm font-medium text-accent">About</p>
        <h1 class="text-3xl font-bold sm:text-4xl">{SITE.title}</h1>
        <p class="mt-5 max-w-2xl leading-8">
          你好👋，我是 Vivi，<br />
          04 年江苏人，ISTJ-A/天蝎座，<br />
          目前是华东师范大学统计学与计算机科学与技术双学位大四本科生，预计于 2026
          年 9 月入学上海交通大学，攻读应用统计硕士。<br />
          作为 28 届应届毕业生，我先后在字节跳动、莉莉丝游戏和腾讯进行实习，分别
          参与策略分析、数据风控和数据科学相关工作。<br />
          我主要关注机器学习、LLM 和 Agent 在业务场景中的落地应用。
        </p>
      </div>
    </section>

    <section class="mt-14">
      <h2 class="text-xl font-semibold">技能标签</h2>
      <ul class="mt-5 flex flex-wrap gap-3">
        {
          skills.map(skill => (
            <li class="rounded border border-border px-3 py-1.5 text-sm">
              {skill}
            </li>
          ))
        }
      </ul>
    </section>

    <section class="mt-14">
      <h2 class="text-xl font-semibold">联系方式</h2>
      <ul class="mt-5 flex flex-wrap gap-4">
        {
          contacts.map(({ name, href, icon: Icon }) => (
            <li>
              {
                name === "Email" ? (
                  <div class="flex items-center gap-3">
                    <button
                      type="button"
                      class="inline-flex items-center gap-2 rounded border border-border px-4 py-2 hover:border-accent hover:text-accent"
                      data-copy-email
                      data-email={email}
                    >
                      <Icon class="size-5" />
                      {email}
                    </button>
                    <span
                      class="text-sm text-accent opacity-0 transition-opacity duration-200"
                      data-copy-status
                      aria-live="polite"
                    >
                      已复制到剪贴板
                    </span>
                  </div>
                ) : (
                  <a
                    href={href}
                    class="inline-flex items-center gap-2 rounded border border-border px-4 py-2 hover:border-accent hover:text-accent"
                    target={href.startsWith("http") ? "_blank" : undefined}
                    rel={href.startsWith("http") ? "noreferrer" : undefined}
                  >
                    <Icon class="size-5" />
                    {name}
                  </a>
                )
              }
            </li>
          ))
        }
      </ul>
    </section>
  </main>
  <Footer />
</Layout>

<script is:inline>
  const copyButton = document.querySelector("[data-copy-email]");
  const copyStatus = document.querySelector("[data-copy-status]");

  if (copyButton && copyStatus) {
    let hideStatusTimer;
    copyButton.addEventListener("click", async () => {
      const email = copyButton.getAttribute("data-email") ?? "";

      try {
        await navigator.clipboard.writeText(email);
        copyStatus.textContent = "已复制到剪贴板";
        copyStatus.classList.remove("opacity-0");
        copyStatus.classList.add("opacity-100");

        window.clearTimeout(hideStatusTimer);
        hideStatusTimer = window.setTimeout(() => {
          copyStatus.classList.remove("opacity-100");
          copyStatus.classList.add("opacity-0");
        }, 1800);
      } catch {
        copyStatus.textContent = "复制失败，请手动复制";
        copyStatus.classList.remove("opacity-0");
        copyStatus.classList.add("opacity-100");
      }
    });
  }
</script>