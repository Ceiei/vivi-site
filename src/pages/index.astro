---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { withBase } from "@/utils/withBase";

const modules = [
  {
    title: "关于我",
    href: "/about",
    description: "个人介绍、技能标签和联系方式。",
  },
  {
    title: "AI学习笔记",
    href: "/blog",
    description: "论文阅读、模型实践和工具链记录。",
  },
  {
    title: "项目展示",
    href: "/projects",
    description: "整理做过的项目、代码仓库和演示链接。",
  },
  {
    title: "碎碎念",
    href: "/notes",
    description: "一些短记录、想法和阶段性观察。",
  },
];
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section class="py-16 sm:py-24">
      <p class="mb-4 text-sm font-medium text-accent">Personal Website</p>
      <h1 class="max-w-2xl text-4xl font-bold sm:text-5xl">{SITE.title}</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8">
        {/* // TODO: 替换为你的一句话介绍 */}
        这里是一句个人介绍占位文案，用来说明你是谁、关注什么方向，以及这个网站会记录什么。
      </p>
    </section>

    <section class="grid gap-4 pb-16 sm:grid-cols-2">
      {
        modules.map(module => (
          <a
            href={withBase(module.href)}
            class="group rounded border border-border p-6 transition hover:border-accent hover:bg-muted/30"
          >
            <h2 class="text-xl font-semibold group-hover:text-accent">
              {module.title}
            </h2>
            <p class="mt-3 min-h-12">{module.description}</p>
            <span class="mt-4 inline-flex items-center gap-1 group-hover:text-accent">
              进入
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </span>
          </a>
        ))
      }
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", import.meta.env.BASE_URL);
    }
  });
</script>