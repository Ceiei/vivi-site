---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import IconGitHub from "@/assets/icons/IconGitHub.svg";
import IconMail from "@/assets/icons/IconMail.svg";
import { SITE } from "@/config";

// TODO: 替换为你的技能列表
const skills = ["AI", "Machine Learning", "Python", "Astro", "Research"];

// TODO: 替换为你的联系方式
const contacts = [
  {
    name: "GitHub",
    href: "https://github.com/your-username",
    icon: IconGitHub,
  },
  {
    name: "Email",
    href: "mailto:your-email@example.com",
    icon: IconMail,
  },
];
---

<Layout title={`关于我 | ${SITE.title}`}>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    class="app-layout min-h-[calc(100svh-9rem)] py-12 sm:py-16 lg:py-24"
  >
    <section class="grid gap-10 lg:grid-cols-[18rem_1fr] lg:items-center">
      <div
        class="flex size-40 shrink-0 items-center justify-center rounded-full border border-dashed border-border bg-muted/30 text-sm text-foreground/70 sm:size-48 lg:size-64"
        aria-label="头像占位区"
      >
        {/* // TODO: 添加头像文件 src/assets/avatar.jpg 后，在这里替换为图片 */}
        Avatar
      </div>

      <div>
        <p class="mb-3 text-sm font-medium text-accent">About</p>
        <h1 class="text-4xl font-bold sm:text-5xl lg:text-6xl">
          {SITE.title}
        </h1>
        <p class="mt-6 max-w-4xl text-lg leading-9">
          {/* // TODO: 替换为你的个人介绍 */}
          这里是一段个人介绍占位文案。你可以介绍自己的学习方向、研究兴趣、当前关注的
          AI 主题，以及这个网站希望沉淀的内容。
        </p>
      </div>
    </section>

    <section class="mt-16 lg:mt-24">
      <h2 class="text-xl font-semibold">技能标签</h2>
      <ul class="mt-5 flex flex-wrap gap-3">
        {
          skills.map(skill => (
            <li class="rounded border border-border px-4 py-2 text-sm">
              {skill}
            </li>
          ))
        }
      </ul>
    </section>

    <section class="mt-14 lg:mt-20">
      <h2 class="text-xl font-semibold">联系方式</h2>
      <ul class="mt-5 flex flex-wrap gap-4">
        {
          contacts.map(({ name, href, icon: Icon }) => (
            <li>
              <a
                href={href}
                class="inline-flex items-center gap-2 rounded border border-border px-4 py-2 hover:border-accent hover:text-accent"
                target={href.startsWith("http") ? "_blank" : undefined}
                rel={href.startsWith("http") ? "noreferrer" : undefined}
              >
                <Icon class="size-5" />
                {name}
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", import.meta.env.BASE_URL);
    }
  });
</script>
