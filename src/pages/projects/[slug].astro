---
import type { GetStaticPaths } from "astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BackButton from "@/components/BackButton.astro";
import LinkButton from "@/components/LinkButton.astro";
import IconGitHub from "@/assets/icons/IconGitHub.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { projects } from "@/data/projects";

export const getStaticPaths = (async () => {
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}) satisfies GetStaticPaths;

const { project } = Astro.props;
---

<Layout
  title={`${project.title} | ${SITE.title}`}
  description={project.description}
>
  <Header />
  <BackButton href="/projects#project-intro" label="返回项目汇总" />

  <main id="main-content" class="app-layout py-12 sm:py-16">
    <div class="space-y-8">
      <div class="space-y-3">
        <p class="text-sm font-medium tracking-[0.24em] text-accent uppercase">
          Project
        </p>
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
          {project.title}
        </h1>
        <p class="max-w-3xl leading-8 text-foreground/80">
          {project.description}
        </p>
      </div>

      <section class="rounded-2xl border border-border bg-background p-5">
        <h2 class="text-xl font-semibold">项目简介</h2>
        <p class="mt-4 text-base leading-8 text-foreground/80">
          {project.fullDescription}
        </p>

        <dl class="mt-5 grid gap-4 text-sm text-foreground/75">
          <div>
            <dt class="font-semibold text-foreground">技术栈</dt>
            <dd class="mt-2 flex flex-wrap gap-2">
              {
                project.tags.map(tag => (
                  <span class="rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-xs font-medium text-sky-700 dark:border-sky-400/20 dark:bg-sky-400/10 dark:text-sky-200">
                    {tag}
                  </span>
                ))
              }
            </dd>
          </div>
        </dl>

        {
          (project.githubUrl || project.demoUrl) && (
            <div class="mt-5 flex flex-wrap gap-3">
              {project.githubUrl && (
                <LinkButton
                  href={project.githubUrl}
                  target="_blank"
                  rel="noreferrer"
                >
                  <IconGitHub class="size-4" />
                  GitHub
                </LinkButton>
              )}
              {project.demoUrl && (
                <LinkButton
                  href={project.demoUrl}
                  target="_blank"
                  rel="noreferrer"
                >
                  Demo
                  <IconArrowRight class="size-4 rtl:-rotate-180" />
                </LinkButton>
              )}
            </div>
          )
        }
      </section>

      <section class="space-y-5">
        <div class="rounded-2xl border border-border bg-background p-5">
          <h2 class="text-xl font-semibold">研究问题</h2>
          <ol
            class="mt-4 list-decimal space-y-3 ps-5 text-base leading-8 text-foreground/80 marker:font-semibold marker:text-accent"
          >
            {project.researchQuestions.map(item => <li>{item}</li>)}
          </ol>
        </div>

        <div class="rounded-2xl border border-border bg-background p-5">
          <h2 class="text-xl font-semibold">解决方案</h2>
          <ol
            class="mt-4 list-decimal space-y-3 ps-5 text-base leading-8 text-foreground/80 marker:font-semibold marker:text-accent"
          >
            {project.solution.map(item => <li>{item}</li>)}
          </ol>
        </div>

        <div class="rounded-2xl border border-border bg-background p-5">
          <h2 class="text-xl font-semibold">主要贡献</h2>
          <ol
            class="mt-4 list-decimal space-y-3 ps-5 text-base leading-8 text-foreground/80 marker:font-semibold marker:text-accent"
          >
            {project.contributions.map(item => <li>{item}</li>)}
          </ol>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</Layout>
